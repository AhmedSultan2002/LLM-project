# Hugging Face access token (required for Llama 3.2 — gated model)
# Get yours at: https://huggingface.co/settings/tokens
# Alternatively, run: python -c "from huggingface_hub import login; login()"
HUGGING_FACE_HUB_TOKEN=your_token_here
